# fc-runner configuration
# Copy to /etc/fc-runner/config.toml and fill in your values.

[github]
# Personal access token (see docs/setup.md for generation guide)
token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
owner = "your-org"
# Single repo (simple setup)
repo = "your-repo"
# Multiple repos under the same owner (overrides repo if both set)
# repos = ["repo-one", "repo-two", "repo-three"]
# Runner group ID (1 = default group)
runner_group_id = 1
# Labels the runner advertises — must match workflow's runs-on
labels = ["self-hosted", "linux", "firecracker"]

[firecracker]
binary_path = "/usr/local/bin/firecracker"
kernel_path = "/opt/fc-runner/vmlinux.bin"
rootfs_golden = "/opt/fc-runner/runner-rootfs-golden.ext4"
vcpu_count = 2
mem_size_mib = 2048
# Kernel boot arguments (default shown below)
# boot_args = "console=ttyS0 reboot=k panic=1 pci=off"
# Firecracker log level: Error, Warning, Info, Debug (default: Warning)
# log_level = "Info"
# Jailer: chroot + seccomp-BPF + UID/GID drop (recommended for production)
# Uncomment the lines below to enable jailer. jailer_uid and jailer_gid are
# required when jailer_path is set.
# jailer_path = "/usr/local/bin/jailer"
# jailer_uid = 1000
# jailer_gid = 1000
# jailer_chroot_base = "/srv/jailer"
# Cloud image URL for golden rootfs build (default: Ubuntu 24.04 minimal)
# cloud_img_url = "https://cloud-images.ubuntu.com/minimal/releases/noble/release/ubuntu-24.04-minimal-cloudimg-amd64.img"
# Secret injection method: "mmds" (default) or "mount" (legacy loop-mount)
# MMDS uses Firecracker's built-in metadata service at 169.254.169.254.
# Mount injects secrets directly into the rootfs via loop mount.
# secret_injection = "mmds"

[runner]
work_dir = "/var/lib/fc-runner/vms"
poll_interval_secs = 5
# Maximum number of VMs running simultaneously (prevents resource exhaustion)
max_concurrent_jobs = 4
# Maximum time (seconds) a single VM is allowed to run before being killed
vm_timeout_secs = 3600
# Warm pool: pre-register N idle runners that wait for GitHub to assign jobs.
# When > 0, uses registration tokens instead of JIT — runners boot and wait.
# When a runner finishes a job, a replacement VM is spawned automatically.
# Set to 0 (default) for reactive JIT mode (VMs created on-demand per job).
# warm_pool_size = 2

# Network is auto-configured at startup (IP forwarding, NAT rules).
# TAP devices are created per-VM with unique subnets (172.16.{slot}.0/24).
[network]
host_ip = "172.16.0.1"
guest_ip = "172.16.0.2"
cidr = "24"
# DNS servers for guest VMs (multiple for redundancy)
dns = ["8.8.8.8", "1.1.1.1"]
# Allowed outbound networks for guest VMs.
# "github" is a magic keyword that auto-fetches GitHub Actions/API/Git/Web CIDRs
# from https://api.github.com/meta at startup.
# When empty or omitted, all outbound traffic is allowed.
# DNS servers are always allowed automatically.
# allowed_networks = ["github"]
# allowed_networks = ["github", "10.0.0.0/8", "192.168.1.0/24"]
