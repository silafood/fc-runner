# fc-runner configuration
# Copy to /etc/fc-runner/config.toml and fill in your values.

[github]
# Authentication: Use either a PAT (token) or GitHub App (app section below).
# Personal access token (see docs/setup.md for generation guide)
token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
owner = "your-org"
# Organization-level runners (optional).
# When set, runners register at the org level and can pick up jobs
# from any repo in the organization. Repos list is still used for filtering.
# organization = "your-org"
# Single repo (simple setup)
repo = "your-repo"
# Multiple repos under the same owner (overrides repo if both set)
# repos = ["repo-one", "repo-two", "repo-three"]
# Runner group ID (1 = default group)
runner_group_id = 1
# Labels the runner advertises — must match workflow's runs-on
labels = ["self-hosted", "linux", "firecracker"]
# GitHub App authentication (alternative to PAT, provides higher rate limits).
# Uncomment to use instead of token above.
# [github.app]
# app_id = 12345
# installation_id = 67890
# private_key_path = "/etc/fc-runner/app-key.pem"

[firecracker]
binary_path = "/usr/local/bin/firecracker"
kernel_path = "/opt/fc-runner/vmlinux.bin"
# URL to download the kernel from if kernel_path does not exist.
# Defaults to the Firecracker CI kernel from Amazon S3.
# kernel_url = "https://github.com/silafood/fc-runner/releases/download/v0.3.0/vmlinux-6.1.102"
rootfs_golden = "/opt/fc-runner/runner-rootfs-golden.ext4"
# OCI image reference (recommended over cloud image build).
# When set, the image is pulled from the registry, extracted to ext4,
# and cached at rootfs_golden path. Supports Docker Hub, GHCR, etc.
# A public base image is available — or use your own:
# image = "ghcr.io/silafood/fc-runner-image:567e784"
vcpu_count = 2
mem_size_mib = 2048
# Kernel boot arguments (default shown below)
# boot_args = "console=ttyS0 reboot=k panic=1 pci=off root=/dev/vda"
# Firecracker log level: Error, Warning, Info, Debug (default: Warning)
# log_level = "Info"
# Jailer: chroot + seccomp-BPF + UID/GID drop (recommended for production)
# Uncomment the lines below to enable jailer. jailer_uid and jailer_gid are
# required when jailer_path is set.
# jailer_path = "/usr/local/bin/jailer"
# jailer_uid = 1000
# jailer_gid = 1000
# jailer_chroot_base = "/var/lib/fc-runner/jailer"
# Cloud image URL for golden rootfs build (default: Ubuntu 24.04 minimal)
# cloud_img_url = "https://cloud-images.ubuntu.com/minimal/releases/noble/release/ubuntu-24.04-minimal-cloudimg-amd64.img"
# Secret injection method: "mmds" (default) or "mount" (legacy loop-mount)
# MMDS uses Firecracker's built-in metadata service at 169.254.169.254.
# Mount injects secrets directly into the rootfs via loop mount.
# secret_injection = "mmds"
# VSOCK: enable virtio-vsock for guest agent communication.
# Each VM gets CID = vsock_cid_base + slot (CIDs 0-2 are reserved).
# vsock_enabled = true
# vsock_cid_base = 3
# OverlayFS COW rootfs mode (enabled by default, requires squashfs-tools on host).
# The golden rootfs is converted to squashfs and shared read-only across all VMs.
# Each VM gets a small sparse ext4 overlay for writes (~1ms vs full copy).
# Set to false to fall back to cp --reflink (legacy mode).
# overlay_rootfs = true
# overlay_size_mib = 512  # Per-VM overlay device size in MiB

[runner]
work_dir = "/var/lib/fc-runner/vms"
poll_interval_secs = 5
# Maximum number of VMs running simultaneously (prevents resource exhaustion)
max_concurrent_jobs = 4
# Maximum time (seconds) a single VM is allowed to run before being killed
vm_timeout_secs = 3600
# Warm pool: pre-register N idle runners that wait for GitHub to assign jobs.
# When > 0, uses registration tokens instead of JIT — runners boot and wait.
# When a runner finishes a job, a replacement VM is spawned automatically.
# Set to 0 (default) for reactive JIT mode (VMs created on-demand per job).
# warm_pool_size = 2
# Ephemeral runners (default: true). When true, runners accept one job then exit
# and a replacement VM is spawned. When false, runners stay alive and accept
# multiple jobs without being replaced — faster job pickup but no isolation
# between jobs. Only applies to warm pool and named pool modes.
# ephemeral = true

# Named VM pools (alternative to warm_pool_size).
# Each pool maintains its own set of pre-registered runners with independent
# resource configs. Pools are distributed across available slots.
# When [[pool]] is configured, warm_pool_size is ignored.
#
# [[pool]]
# name = "default"
# repos = ["repo-a", "repo-b"]
# min_ready = 2
# max_ready = 4
# # Optional resource overrides (defaults to [firecracker] values)
# # vcpu_count = 4
# # mem_size_mib = 4096
#
# [[pool]]
# name = "heavy"
# repos = ["repo-c"]
# min_ready = 1
# max_ready = 2
# vcpu_count = 8
# mem_size_mib = 8192

# Network is auto-configured at startup (IP forwarding, NAT rules).
# TAP devices are created per-VM with unique subnets (172.16.{slot}.0/24).
[network]
host_ip = "172.16.0.1"
guest_ip = "172.16.0.2"
cidr = "24"
# DNS servers for guest VMs (multiple for redundancy)
dns = ["8.8.8.8", "1.1.1.1"]
# Allowed outbound networks for guest VMs.
# "github" is a magic keyword that auto-fetches GitHub Actions/API/Git/Web CIDRs
# from https://api.github.com/meta at startup.
# When empty or omitted, all outbound traffic is allowed.
# DNS servers are always allowed automatically.
# allowed_networks = ["github"]
# allowed_networks = ["github", "10.0.0.0/8", "192.168.1.0/24"]

# Management and metrics HTTP server
[server]
# Set to false to disable the HTTP server entirely
# enabled = true
# Listen address for /metrics (Prometheus), /healthz, /api/v1/* endpoints
# listen_addr = "0.0.0.0:9090"
# Optional API key for management endpoints (X-Api-Key header)
# api_key = "your-secret-key"
